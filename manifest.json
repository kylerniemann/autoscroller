
{
  "manifest_version": 3,
  "name": "AutoScroller",
  "version": "1.0",
  "description": "Auto-scroll pages with adjustable speed, pause, and auto-start.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AutoScroller"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
